# ─────────────────────────────────────────────────────────────────────────────
# Talentora AI – Environment Variables
# Copy this file to .env and fill in the values.
# Never commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://talentora:change_me@localhost:5432/talentora
POSTGRES_USER=talentora
POSTGRES_PASSWORD=change_me
POSTGRES_DB=talentora

# ── Redis / Celery ────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Security ──────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change_me_generate_a_strong_secret_key_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ── Stripe Billing ────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_STARTER_PRICE_ID=price_...
STRIPE_PRO_PRICE_ID=price_...
STRIPE_TEAM_PRICE_ID=price_...

# ── AWS / S3 Storage ──────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...
AWS_S3_BUCKET=talentora-data-dev
AWS_REGION=eu-west-3

# ── France Travail (Pôle Emploi) API ─────────────────────────────────────────
# Register at: https://francetravail.io/produits-api
FRANCE_TRAVAIL_CLIENT_ID=your_client_id
FRANCE_TRAVAIL_CLIENT_SECRET=your_client_secret

# ── Next.js / Frontend ────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# ── Application ───────────────────────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO
# Comma-separated list of allowed CORS origins
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── Flower (Celery monitoring) ────────────────────────────────────────────────
FLOWER_BASIC_AUTH=admin:change_me
